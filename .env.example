# انسخ هذا الملف باسم .env واملأ القيم المناسبة لبيئتك المحلية.
# لا تضف ملف .env الفعلي إلى Git أبداً (محمي عبر .gitignore).

SECRET_KEY=ضع-مفتاح-سري-عشوائي-هنا
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── قاعدة البيانات ──
# اتركها فارغة لاستخدام SQLite (التطوير المحلي حالياً).
# عند الانتقال لاحقاً إلى PostgreSQL، فعّل القيم التالية:
# DB_ENGINE=postgresql
# DB_NAME=wassel_db
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432
